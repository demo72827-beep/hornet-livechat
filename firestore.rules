rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Agent = email/password login (non-anonymous)
    function isAgent() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }
    // Visitor = anonymous login
    function isVisitor() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    match /conversations/{convId} {
      // Agents sab conversations dekh/update kar sakte hain
      allow read, write: if isAgent();
      // Visitors apni conversation create/update kar sakte hain (read nahi list)
      allow create, update: if isVisitor();
      allow get: if isVisitor();

      match /messages/{msgId} {
        allow read: if isAgent() || isVisitor();
        allow create: if (isAgent() && request.resource.data.from == 'agent')
                   || (isVisitor() && request.resource.data.from == 'visitor');
        // Messages kabhi edit/delete nahi hote
        allow update, delete: if false;
      }
    }
  }
}
