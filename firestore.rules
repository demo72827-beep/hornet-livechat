rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MASTER ADMIN — apna email yahan daalo (firebase-config.js wale se SAME)
    function isSuper() {
      return request.auth != null
        && request.auth.token.email == 'masterpanel@gmail.com';
    }
    function isUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'password';
    }
    function isVisitor() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Customer accounts
    match /users/{uid} {
      allow create, update: if isUser() && request.auth.uid == uid;
      allow read: if isSuper() || (isUser() && request.auth.uid == uid);
      allow delete: if false;
    }

    // Chat widgets (projects). Widget needs public "get" to load branding.
    match /projects/{pid} {
      allow get: if request.auth != null;
      allow list: if isSuper() || (isUser() && resource.data.ownerUid == request.auth.uid);
      allow create: if isUser() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSuper() || (isUser() && resource.data.ownerUid == request.auth.uid);
      allow delete: if isSuper();
    }

    match /conversations/{convId} {
      allow read: if isSuper()
        || (isUser() && resource.data.ownerUid == request.auth.uid)
        || isVisitor();
      allow create, update: if isVisitor()
        || isSuper()
        || (isUser() && resource.data.ownerUid == request.auth.uid);
      allow delete: if isSuper();

      match /messages/{msgId} {
        allow read: if isSuper() || isUser() || isVisitor();
        allow create: if (isUser() && request.resource.data.from == 'agent')
                   || (isVisitor() && request.resource.data.from == 'visitor');
        allow update, delete: if false;
      }
    }
  }
}
